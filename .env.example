# Postgres (Railway plugin connection string)
DATABASE_URL=postgres://user:pass@host:5432/brood_tapper

# Portal external-module launch auth
MODULE_LAUNCH_SECRET=replace-with-module-secret-from-portal-cms
PORTAL_ISSUER=https://portal.raidguild.org
MODULE_SLUG=brood-tapper
PORTAL_MODULES_URL=https://portal.raidguild.org/modules

# iron-session cookie encryption (32+ chars)
SESSION_SECRET=replace-with-a-random-32-plus-char-string

# Read-only reporting API for trusted agents
BROOD_TAPPER_AGENT_API_TOKEN=replace-with-a-random-agent-api-token
